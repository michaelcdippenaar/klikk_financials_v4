# Copy this file to .env and fill in values before running docker-compose

# Django
DJANGO_SETTINGS_MODULE=klikk_business_intelligence.settings.staging
DJANGO_SECRET_KEY=change-me-use-secrets-token-urlsafe-50

# Media and Xero documents (app server e.g. 192.168.1.235). Uncomment and set on that host.
# MEDIA_ROOT=/var/data/klikk_financials_v4/media
XERO_DOCUMENTS_ROOT=/var/data/klikk_financials_v4/xero_documents

# Allowed hosts (comma-separated, no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1,102.135.240.222

# Database (used by Django and the db service)
DB_NAME=klikk_financials_v4
DB_USER=klikk_user
DB_PASSWORD=change-me
# Postgres runs on the host machine, not inside Docker.
# Leave as host-gateway (resolved via extra_hosts in docker-compose.yml).
DB_HOST=host-gateway
DB_PORT=5432

# GitHub webhook (optional)
GITHUB_WEBHOOK_SECRET=

# Google Cloud / BigQuery (optional)
GOOGLE_APPLICATION_CREDENTIALS=

# AI Agent / OpenAI (optional)
# DO NOT commit real keys. Put real values in .env.local
AI_AGENT_OPENAI_API_KEY=
# Chat model: gpt-4o-mini, gpt-4o, gpt-5.2, gpt-5.2-instant, gpt-5.2-thinking, gpt-5.2-pro, gpt-5-mini
AI_AGENT_MODEL=gpt-5.2
AI_AGENT_EMBEDDING_MODEL=text-embedding-3-small
# Web search (optional): get key at https://serper.dev to enable stock price, look up, real-time web search
SERPER_API_KEY=
